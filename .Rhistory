# 1) Make sure it's a plain 2-col object
wl <- as.data.frame(whitelist, stringsAsFactors = FALSE)
# If columns aren't named, bnlearn expects 2 columns anyway; name them for safety:
names(wl)[1:2] <- c("from", "to")
# 2) Drop rows with NA (or empty strings)
wl <- wl[!is.na(wl$from) & !is.na(wl$to), , drop = FALSE]
wl <- wl[wl$from != "" & wl$to != "", , drop = FALSE]
# 3) Trim whitespace (hidden spaces are a common culprit too)
wl$from <- trimws(wl$from)
wl$to   <- trimws(wl$to)
# 4) Keep only arcs whose node labels exist in the data
nodes <- names(df)  # df is the data you pass to hc()
wl <- wl[wl$from %in% nodes & wl$to %in% nodes, , drop = FALSE]
# 5) Remove duplicates
wl <- unique(wl)
# Now run
bn <- hc(df, score = "bic-cg", whitelist = wl)
