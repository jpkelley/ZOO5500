df$bird_id <- factor(df$bird)
df$age_class <- factor(df$age_class)
df$predator_playback <- factor(df$predator_playback)
# save data
write.csv(df, "../../quant_course_sp2026/chapters/data/lepus_expt.csv", row.names=F)
